<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        x:Class="NetClassManage.Views.NotificationWindow"
        Icon="/Assets/icon.ico"
        Title="服务器通知"
        Width="450" Height="240"
        MinWidth="380" MinHeight="200"
        WindowStartupLocation="Manual"
        Topmost="True"
        ShowInTaskbar="False"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="NoChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        CanResize="False"
        TransparencyLevelHint="AcrylicBlur">

    <Border x:Name="MainBorder"
            CornerRadius="8"
            Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
            BorderBrush="{DynamicResource SystemAccentColor}"
            BorderThickness="1"
            BoxShadow="0 4 16 4 #40000000">
        <Border.RenderTransform>
            <TranslateTransform/>
        </Border.RenderTransform>
        <Grid RowDefinitions="Auto,*,Auto" Margin="24,20,24,20">
            <StackPanel Grid.Row="0" Spacing="10">
                <Grid ColumnDefinitions="Auto,*,Auto">
                    <fa:SymbolIcon x:Name="IconSymbol" Symbol="Alert" FontSize="26" Foreground="{DynamicResource SystemAccentColor}"/>
                    <TextBlock Grid.Column="1" x:Name="TitleText"
                              Text="服务器通知" 
                              FontSize="20" FontWeight="SemiBold"
                              VerticalAlignment="Center" Margin="14,0,0,0"/>
                    <Border Grid.Column="2" x:Name="PriorityBadge"
                            CornerRadius="4"
                            Padding="8,2,8,2"
                            Background="{DynamicResource SystemAccentColor}"
                            Margin="8,0,0,0">
                        <TextBlock x:Name="PriorityText"
                                  Text="一般"
                                  FontSize="12"
                                  FontWeight="SemiBold"
                                  Foreground="White"/>
                    </Border>
                </Grid>
                <Border Height="1" Background="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" Margin="0,6,0,0"/>
            </StackPanel>

            <ScrollViewer Grid.Row="1" Margin="0,16,0,0" MaxHeight="150">
                <TextBlock x:Name="MessageText" 
                          TextWrapping="Wrap"
                          FontSize="16"
                          Text="通知内容"/>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8" Margin="0,16,0,0">
                <Button x:Name="CancelButton" Content="取消关机" 
                        Classes="accent"
                        Click="OnCancelClick"
                        Width="90" Height="36"
                        FontSize="14"
                        IsVisible="False"/>
                <Button x:Name="ConfirmButton" Content="确定" 
                        Classes="accent"
                        Click="OnConfirmClick"
                        Width="90" Height="36"
                        FontSize="14"
                        IsEnabled="False"/>
                <TextBlock x:Name="CountdownText" 
                          Text="5秒后可关闭"
                          FontSize="13"
                          VerticalAlignment="Center"
                          Margin="8,0,0,0"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
