<faw:AppWindow xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        xmlns:faw="clr-namespace:FluentAvalonia.UI.Windowing;assembly=FluentAvalonia"
        xmlns:vm="using:NetClassManage.ViewModels"
        xmlns:views="using:NetClassManage.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="700"
        x:Class="NetClassManage.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/icon.ico"
        Title="NetClassMgr 客户端"
        Width="900" Height="700"
        MinWidth="800" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="-1"
        TransparencyLevelHint="AcrylicBlur">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Height="32" Background="Transparent">
            <TextBlock Text="NetClassMgr 客户端" 
                       FontSize="12"
                       FontWeight="Medium"
                       VerticalAlignment="Center"
                       Margin="16,0,0,0"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
        </Border>

        <fa:NavigationView Grid.Row="1"
                          x:Name="NavView"
                          PaneDisplayMode="Left"
                          IsSettingsVisible="False"
                          OpenPaneLength="220"
                          CompactPaneLength="48"
                          SelectionChanged="NavView_SelectionChanged">
            
            <fa:NavigationView.MenuItems>
                <fa:NavigationViewItem Content="连接设置" Tag="Connect"/>
                <fa:NavigationViewItem Content="设备管理" Tag="Device"/>
                <fa:NavigationViewItem Content="通知历史" Tag="Notification"/>
                <fa:NavigationViewItem Content="更新管理" Tag="Update"/>
                <fa:NavigationViewItem Content="日志查看" Tag="Log"/>
            </fa:NavigationView.MenuItems>
            
            <fa:NavigationView.FooterMenuItems>
                <fa:NavigationViewItem Content="桌面小组件" Tag="Widget"/>
                <fa:NavigationViewItem Content="关于" Tag="About"/>
            </fa:NavigationView.FooterMenuItems>

            <ScrollViewer Padding="24,16,24,24">
                <StackPanel Spacing="16">
                    
                    <StackPanel Spacing="16" IsVisible="{Binding IsConnectPage}">
                        <TextBlock Text="连接设置" FontSize="24" FontWeight="SemiBold"/>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="服务器配置" FontSize="16" FontWeight="SemiBold"/>
                                
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="服务器地址:" 
                                               VerticalAlignment="Center" Width="100"/>
                                    <TextBox Grid.Row="0" Grid.Column="1" 
                                             Text="{Binding ServerUrl}" 
                                             IsReadOnly="False" 
                                             Watermark="https://ncmgr.nbjqc.cn"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="连接令牌:" 
                                               VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBox Grid.Row="1" Grid.Column="1" 
                                             Text="{Binding Token}" 
                                             PasswordChar="●"
                                             Margin="0,8,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="设备名称:" 
                                               VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBox Grid.Row="2" Grid.Column="1" 
                                             Text="{Binding DeviceName}" 
                                             Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="连接选项" FontSize="16" FontWeight="SemiBold"/>
                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <CheckBox Content="启动时自动连接" 
                                              IsChecked="{Binding AutoConnect}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="心跳间隔(秒):" VerticalAlignment="Center"/>
                                        <fa:NumberBox Value="{Binding HeartbeatInterval}" 
                                                   Minimum="5" Maximum="300" Width="80"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Grid ColumnDefinitions="*,*,*,*" Margin="0,8">
                            <Button Grid.Column="0" Content="连接服务器" 
                                    Click="OnConnectClick"
                                    HorizontalAlignment="Stretch" Margin="0,0,8,0"
                                    Classes="accent"/>
                            <Button Grid.Column="1" Content="断开连接" 
                                    Click="OnDisconnectClick"
                                    IsEnabled="{Binding IsConnected}"
                                    HorizontalAlignment="Stretch" Margin="8,0,8,0"/>
                            <Button Grid.Column="2" Content="保存配置" 
                                    Click="OnSaveClick"
                                    HorizontalAlignment="Stretch" Margin="8,0,8,0"/>
                            <Button Grid.Column="3" Content="测试连接" 
                                    Click="OnTestClick"
                                    HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                        </Grid>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="8">
                                <TextBlock Text="连接状态" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding StatusText}" TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="16" IsVisible="{Binding IsDevicePage}">
                        <TextBlock Text="设备管理" FontSize="24" FontWeight="SemiBold"/>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="设备信息" FontSize="16" FontWeight="SemiBold"/>
                                
                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Text="设备ID:" 
                                               VerticalAlignment="Center" Width="100"/>
                                    <TextBlock Grid.Row="0" Grid.Column="1" 
                                               Text="{Binding DeviceId}"
                                               FontWeight="Medium"/>

                                    <TextBlock Grid.Row="1" Grid.Column="0" Text="设备状态:" 
                                               VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="1" Grid.Column="1" 
                                               Text="{Binding DeviceStatus}"
                                               Margin="0,8,0,0"/>

                                    <TextBlock Grid.Row="2" Grid.Column="0" Text="最后在线:" 
                                               VerticalAlignment="Center" Margin="0,8,0,0"/>
                                    <TextBlock Grid.Row="2" Grid.Column="1" 
                                               Text="{Binding LastOnlineTime}"
                                               Margin="0,8,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="设备操作" FontSize="16" FontWeight="SemiBold"/>
                                <Grid ColumnDefinitions="*,*" Margin="0,8">
                                    <Button Grid.Column="0" Content="刷新状态" 
                                            Click="OnRefreshDeviceClick"
                                            HorizontalAlignment="Stretch" Margin="0,0,8,0"/>
                                    <Button Grid.Column="1" Content="重启设备" 
                                            Click="OnRestartDeviceClick"
                                            HorizontalAlignment="Stretch" Margin="8,0,0,0"/>
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="16" IsVisible="{Binding IsNotificationPage}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="通知历史" FontSize="24" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Content="清除历史" 
                                    Click="OnClearNotificationClick"/>
                        </Grid>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <ScrollViewer Height="400" VerticalScrollBarVisibility="Auto">
                                <StackPanel x:Name="NotificationsPanel" Spacing="8"/>
                            </ScrollViewer>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="16" IsVisible="{Binding IsUpdatePage}">
                        <TextBlock Text="更新管理" FontSize="24" FontWeight="SemiBold"/>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="自动更新" FontSize="16" FontWeight="SemiBold"/>
                                
                                <Grid ColumnDefinitions="*,Auto">
                                    <CheckBox Content="启用自动更新" 
                                              IsChecked="{Binding AutoUpdate}"/>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="检查间隔(小时):" VerticalAlignment="Center"/>
                                        <fa:NumberBox Value="{Binding CheckInterval}" 
                                                   Minimum="1" Maximum="168" Width="80"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Grid.Column="0" Text="更新状态" 
                                               FontSize="16" FontWeight="SemiBold"/>
                                    <Button Grid.Column="1" Content="检查更新" 
                                            Click="OnCheckUpdateClick"/>
                                </Grid>
                                <TextBlock Text="{Binding UpdateInfo}" TextWrapping="Wrap"/>
                                <ProgressBar IsIndeterminate="{Binding IsCheckingUpdate}"
                                            IsVisible="{Binding IsCheckingUpdate}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20"
                                IsVisible="{Binding HasUpdate}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="发现新版本" FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{DynamicResource SystemAccentColor}"/>
                                <TextBlock Text="{Binding NewVersionInfo}" TextWrapping="Wrap"/>
                                <Button Content="立即更新" 
                                        Click="OnDoUpdateClick"
                                        Classes="accent"
                                        HorizontalAlignment="Left"
                                        IsEnabled="{Binding !IsUpdating}"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20"
                                IsVisible="{Binding IsUpdating}">
                            <StackPanel Spacing="12">
                                <TextBlock Text="正在更新..." FontSize="16" FontWeight="SemiBold" 
                                           Foreground="{DynamicResource SystemAccentColor}"/>
                                <ProgressBar Value="{Binding UpdateProgress}" Maximum="100" Height="20"/>
                                <TextBlock Text="{Binding UpdateProgress, StringFormat={}{0:0.0}%}" 
                                           HorizontalAlignment="Right" 
                                           Foreground="{DynamicResource SystemControlForegroundSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="16" IsVisible="{Binding IsLogPage}">
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Grid.Column="0" Text="日志查看" FontSize="24" FontWeight="SemiBold"/>
                            <Button Grid.Column="1" Content="清除日志" 
                                    Click="OnClearLogClick"/>
                        </Grid>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <TextBox Text="{Binding LogText}" 
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     Height="400"
                                     ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </Border>
                    </StackPanel>

                    <StackPanel Spacing="16" IsVisible="{Binding IsAboutPage}">
                        <TextBlock Text="关于" FontSize="24" FontWeight="SemiBold"/>
                        
                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="NetClassMgr 客户端" FontSize="20" FontWeight="Bold"/>
                                <TextBlock Text="版本: 1.0.0" Foreground="{DynamicResource SystemControlForegroundSecondaryBrush}"/>
                                <TextBlock Text="一个用于管理班级设备的客户端应用程序，支持自动更新、远程管理等功能。"
                                           TextWrapping="Wrap" Margin="0,8,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}" 
                                CornerRadius="8" Padding="20">
                            <StackPanel Spacing="12">
                                <TextBlock Text="技术栈" FontSize="16" FontWeight="SemiBold"/>
                                <TextBlock Text=".NET 8.0 + Avalonia UI + FluentAvaloniaUI"
                                           Foreground="{DynamicResource SystemControlForegroundSecondaryBrush}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                </StackPanel>
            </ScrollViewer>
        </fa:NavigationView>
    </Grid>
</faw:AppWindow>
